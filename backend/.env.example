# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL (production) — comment out to use SQLite for local dev
# DATABASE_URL=postgresql+asyncpg://cascadenet:cascadenet@localhost:5432/cascadenet

# SQLite fallback for local dev (no Docker needed)
DATABASE_URL=sqlite+aiosqlite:///./cascadenet.db

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── ML Service ─────────────────────────────────────────────────────────────
# URL of the AI_ML FastAPI inference service
ML_SERVICE_URL=http://localhost:8000

# ─── Prediction Engine ──────────────────────────────────────────────────────
# How often (minutes) to refresh zone predictions
PREDICTION_CYCLE_MINUTES=30

# ─── Auth ───────────────────────────────────────────────────────────────────
SECRET_KEY=changeme-replace-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
